class Model(nn.Module):
    def __init__(self):
        super().__init__()
        self.n_segments = 400
        self.hidden_dim = 512
        self.num_freqs = 32
        
        freq_bands = torch.linspace(1, 10, self.num_freqs)
        self.register_buffer('freq_bands', freq_bands)
        
        self.input_proj = nn.Sequential(
            nn.Linear(self.num_freqs * 2, self.hidden_dim),
            nn.LayerNorm(self.hidden_dim),
            nn.GELU()
        )
        
        self.res_blocks = nn.ModuleList([
            nn.Sequential(
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim),
                nn.GELU(),
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim)
            ) for _ in range(6)
        ]
        
        self.head_shared = nn.Sequential(
            nn.Linear(self.hidden_dim, self.hidden_dim),
            nn.LayerNorm(self.hidden_dim),
            nn.GELU(),
            nn.Dropout(0.15)
        )
        
        self.head_dose = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        self.head_fluence = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        self.head_let = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )

    def forward(self, energy: torch.Tensor) -> torch.Tensor:
        if energy.dim() == 1:
            energy = energy.unsqueeze(-1)
        
        energy_scaled = energy * self.freq_bands.unsqueeze(0)
        fourier_features = torch.cat([torch.sin(energy_scaled), torch.cos(energy_scaled)], dim=-1)
        
        x = self.input_proj(fourier_features)
        
        for res_block in self.res_blocks:
            x = x + res_block(x)
        
        features = self.head_shared(x)
        
        dose = self.head_dose(features)
        fluence = self.head_fluence(features)
        let = self.head_let(features)
        
        return torch.stack([dose, fluence, let], dim=1)
