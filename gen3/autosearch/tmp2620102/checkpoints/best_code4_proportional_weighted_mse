def weighted_mse_loss(pred, target, idx):
    eps = 1e-9
    sq_err_batch = (pred - target) / (target.abs() + eps)

    indexes = idx.detach().cpu().numpy() // seeds_per_energy
    weighted = (sq_err_batch**2) * weights_tensor_train[indexes]

    return weighted.mean()


