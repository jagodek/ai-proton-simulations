class Model(nn.Module):
    def __init__(self):
        super().__init__()
        self.n_segments = 400
        self.hidden_dim = 256
        
        # Fourier features for capturing Bragg peak frequencies
        self.freq_bands = 16
        self.register_buffer('frequencies', 2.0 ** torch.linspace(0, 4, self.freq_bands))
        
        # Input embedding with Fourier features
        self.input_embed = nn.Sequential(
            nn.Linear(1 + 2*self.freq_bands, self.hidden_dim),
            nn.LayerNorm(self.hidden_dim),
            nn.SiLU(),
            nn.Linear(self.hidden_dim, self.hidden_dim),
            nn.LayerNorm(self.hidden_dim),
            nn.SiLU()
        )
        
        # Deep trunk with residual connections
        self.trunk_blocks = nn.ModuleList([
            nn.Sequential(
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim),
                nn.SiLU(),
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim),
            )
            for _ in range(8)
        ])
        
        # Task-specific processing
        self.task_layers = nn.ModuleList([
            nn.Sequential(
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim),
                nn.SiLU(),
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim),
                nn.SiLU()
            )
            for _ in range(3)
        ])
        
        # Output heads (Softplus for non-negative outputs)
        self.head_dose = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        self.head_fluence = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        self.head_let = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        
        # Learnable smoothing convolution for statistical noise reduction
        self.smooth_conv = nn.Conv1d(
            in_channels=3,
            out_channels=3,
            kernel_size=5,
            padding=2,
            groups=3,
            bias=False
        )
        # Initialize with Gaussian kernel
        with torch.no_grad():
            gaussian_kernel = torch.exp(-torch.linspace(-2, 2, 5)**2 / 2)
            gaussian_kernel = gaussian_kernel / gaussian_kernel.sum()
            for i in range(3):
                self.smooth_conv.weight[i, 0, :] = gaussian_kernel
    
    def encode_position(self, x):
        phases = x * self.frequencies
        return torch.cat([torch.sin(phases), torch.cos(phases)], dim=-1)
    
    def forward(self, energy: torch.Tensor) -> torch.Tensor:
        if energy.dim() == 1:
            energy = energy.unsqueeze(-1)
        
        # Fourier features
        fourier = self.encode_position(energy)
        x = torch.cat([energy, fourier], dim=-1)
        
        # Input embedding
        features = self.input_embed(x)
        
        # Trunk with residual connections
        for block in self.trunk_blocks:
            features = features + block(features)
            features = torch.nn.functional.silu(features)
        
        # Task-specific processing
        dose_feat = self.task_layers[0](features)
        fluence_feat = self.task_layers[1](features)
        let_feat = self.task_layers[2](features)
        
        # Generate outputs
        dose = self.head_dose(dose_feat)
        fluence = self.head_fluence(fluence_feat)
        let_val = self.head_let(let_feat)
        
        # Stack and apply smoothing
        output = torch.stack([dose, fluence, let_val], dim=1)
        output = self.smooth_conv(output)
        
        return output


batch_size = 128
total_epochs = 1000

model = Model().to(device)
optimizer = torch.optim.AdamW(model.parameters(), lr=5e-4, weight_decay=1e-4)
scheduler = torch.optim.lr_scheduler.OneCycleLR(optimizer, max_lr=5e-4, epochs=total_epochs, steps_per_epoch=math.ceil(n_samples/batch_size), pct_start=0.3, anneal_strategy='cos')
# criterion = nn.MSELoss()


model.train()
start_training = time.time()


for epoch in range(total_epochs):
    train_loss = 0.0
    smoothness_loss_total = 0.0
    perm = torch.randperm(n_samples)
    for i in range(0, n_samples, batch_size):
        idx = perm[i:i+batch_size]
        x_batch, y_batch = X_tensor[idx], Y[idx]
        
        optimizer.zero_grad()
        pred = model(x_batch)
        
        # Channel-weighted Huber loss (dose most important)
        dose_loss = weighted_mse_loss(pred[:, 0, :], y_batch[:, 0, :])
        fluence_loss = weighted_mse_loss(pred[:, 1, :], y_batch[:, 1, :])
        let_loss = weighted_mse_loss(pred[:, 2, :], y_batch[:, 2, :])
        base_loss = 0.5 * dose_loss + 0.3 * fluence_loss + 0.2 * let_loss
        
        # Second derivative smoothness (curvature penalty)
        smooth_loss = 0.0
        for ch in range(3):
            pred_ch = pred[:, ch, :]
            second_deriv = pred_ch[:, 2:] - 2 * pred_ch[:, 1:-1] + pred_ch[:, :-2]
            smooth_loss += torch.mean(second_deriv ** 2)
        
        # Combined loss
        total_loss = base_loss + 0.015 * smooth_loss
        
        total_loss.backward()
        
        # Gradient clipping for stability
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        
        optimizer.step()
        train_loss += base_loss.item()
        smoothness_loss_total += smooth_loss.item()
    num_batches = math.ceil(n_samples / batch_size)
    train_loss /= num_batches
    scheduler.step()
    current_lr = optimizer.param_groups[0]['lr']


    if epoch % 50 == 0:
        print(
            f"Epoch {epoch:>4d} | ",
            f"Train loss: {train_loss:.4e} | ",
            f"LR: {current_lr:.2e}",
            f"Time: {time.time()-start_training:.2f}"
        )
