def test_model(model, criterion, device):
    """
    Evaluates the trained model on the test dataset.
    """
    model.eval()

    Y_test = torch.stack(
        [
            torch.tensor(normalized_data_dose_test, dtype=torch.float32),
            torch.tensor(normalized_data_fluence_protons_test, dtype=torch.float32),
            torch.tensor(normalized_data_dlet_protons_test, dtype=torch.float32),
        ],
        dim=1,
    ).to(device)

    X_test_tensor = torch.tensor(data_x_test, dtype=torch.float32).to(device)


    with torch.no_grad():
        predictions = model(X_test_tensor)
        test_loss = criterion(predictions, Y_test).item()
    criterion_name = criterion.__class__.__name__
    print(f"\n--- Model Evaluation ---")
    print(f"Total Test {criterion_name}: {test_loss:.4e}")
    with open(LOGS_PATH, "a+") as logs_file:
        logs_file.write(f"Total Test {criterion_name}: {test_loss:.4e}")
    return test_loss



Y = torch.stack(
    [
        torch.tensor(normalized_data_dose, dtype=torch.float32),
        torch.tensor(normalized_data_fluence_protons, dtype=torch.float32),
        torch.tensor(normalized_data_dlet_protons, dtype=torch.float32),
    ],
    dim=1,
).to(device)
X_tensor = torch.tensor(normalized_x, dtype=torch.float32).to(device)
n_samples = len(X_tensor)


class Model(nn.Module):
    def __init__(self):
        super().__init__()
        self.n_segments = 400
        self.hidden_dim = 256
        
        # Fourier features for better frequency representation
        self.freq_bands = 16
        self.register_buffer('frequencies', 2.0 ** torch.arange(self.freq_bands))
        
        # Input embedding with Fourier features
        self.input_embed = nn.Sequential(
            nn.Linear(1 + 2*self.freq_bands, self.hidden_dim),
            nn.LayerNorm(self.hidden_dim),
            nn.SiLU()
        )
        
        # Deep trunk with residual connections (FIXED - properly closed)
        self.trunk_blocks = nn.ModuleList([
            nn.Sequential(
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim),
                nn.SiLU(),
                nn.Linear(self.hidden_dim, self.hidden_dim),
                nn.LayerNorm(self.hidden_dim),
            )
            for _ in range(4)
        ])
        
        # Task-specific heads (all Softplus for non-negative outputs)
        self.head_dose = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        self.head_fluence = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        self.head_let = nn.Sequential(
            nn.Linear(self.hidden_dim, self.n_segments),
            nn.Softplus()
        )
        
        # Learnable smoothing convolution (enforces smoothness along depth)
        self.smooth_conv = nn.Conv1d(
            in_channels=3,
            out_channels=3,
            kernel_size=9,
            padding=4,
            groups=3
        )
    
    def encode_position(self, x):
        """Fourier feature encoding for better frequency capture"""
        phases = x * self.frequencies
        return torch.cat([torch.sin(phases), torch.cos(phases)], dim=-1)
    
    def forward(self, energy: torch.Tensor) -> torch.Tensor:
        if energy.dim() == 1:
            energy = energy.unsqueeze(-1)
        
        # Fourier features
        fourier = self.encode_position(energy)
        x = torch.cat([energy, fourier], dim=-1)
        
        # Input embedding
        features = self.input_embed(x)
        
        # Trunk with residual connections
        for block in self.trunk_blocks:
            features = features + block(features)
            features = F.silu(features)
        
        # Generate outputs
        dose = self.head_dose(features)
        fluence = self.head_fluence(features)
        let_val = self.head_let(features)
        
        # Stack and apply learnable smoothing
        output = torch.stack([dose, fluence, let_val], dim=1)  # [batch, 3, 400]
        output = self.smooth_conv(output)  # [batch, 3, 400]
        
        return output


batch_size = 128
total_epochs = 1000

model = Model().to(device)
optimizer = torch.optim.AdamW(model.parameters(), lr=3e-4, weight_decay=1e-4)
scheduler = torch.optim.lr_scheduler.CosineAnnealingWarmRestarts(optimizer, T_0=30, T_mult=2, eta_min=1e-7)
criterion = nn.HuberLoss(delta=0.05)


model.train()
start_training = time.time()


for epoch in range(total_epochs):
    train_loss = 0.0
    smoothness_loss_total = 0.0
    perm = torch.randperm(n_samples)
    for i in range(0, n_samples, batch_size):
        idx = perm[i:i+batch_size]
        x_batch, y_batch = X_tensor[idx], Y[idx]
        
        optimizer.zero_grad()
        pred = model(x_batch)
        
        # Main loss
        base_loss = criterion(pred, y_batch)
        
        # Total Variation loss for smoothness (penalize first derivative)
        tv_loss = 0.0
        for ch in range(3):
            pred_ch = pred[:, ch, :]
            first_deriv = pred_ch[:, 1:] - pred_ch[:, :-1]
            tv_loss += torch.mean(torch.abs(first_deriv))
        
        # Second derivative smoothness
        smooth_loss = 0.0
        for ch in range(3):
            pred_ch = pred[:, ch, :]
            second_deriv = pred_ch[:, 2:] - 2 * pred_ch[:, 1:-1] + pred_ch[:, :-2]
            smooth_loss += torch.mean(second_deriv ** 2)
        
        total_loss = base_loss + 0.03 * tv_loss + 0.02 * smooth_loss
        
        total_loss.backward()
        
        # Gradient clipping for stability
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        
        optimizer.step()
        train_loss += base_loss.item()
        smoothness_loss_total += (0.03 * tv_loss + 0.02 * smooth_loss).item()
    num_batches = math.ceil(n_samples / batch_size)
    train_loss /= num_batches
    current_lr = optimizer.param_groups[0]['lr']
    scheduler.step()
    
    if epoch % 50 == 0:
        print(
            f"Epoch {epoch:>4d} | ",
            f"Train loss: {train_loss:.4e} | ",
            f"LR: {current_lr:.2e}",
            f"Time: {time.time()-start_training:.2f}"
        )
        with open(LOGS_PATH,"a+") as logs_file:
            logs_file.write(
                f"Epoch {epoch:>4d} | Train loss: {train_loss:.8e}  | LR: {current_lr:.2e} | Time: {time.time()-start_training:.2f}\n"
            )

final_test_loss = test_model(model, criterion, device)

